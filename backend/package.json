{
  "name": "pibit-cms-backend",
  "version": "1.0.0",
  "description": "PIBIT.AI CMS Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pbt": "vitest run --reporter=verbose",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "generate-dummy": "tsx src/scripts/generateDummyData.ts",
    "load-test": "tsx src/scripts/loadTest.ts",
    "test-analytics": "tsx src/scripts/testAnalytics.ts",
    "migrate": "tsx src/scripts/migrateDatabase.ts"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.3.0",
    "multer": "^2.1.1",
    "uuid": "^9.0.1",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "@types/validator": "^13.11.9",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitest/ui": "^1.3.1",
    "eslint": "^8.57.0",
    "fast-check": "^3.15.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
