# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/pibit-cms

# CORS Configuration (for LAN access)
# Leave empty or set to * for all origins
CORS_ORIGIN=*

# Authentication Configuration (Optional)
# Set to true to enable login authentication
# ENABLE_AUTH=true

# Admin Credentials (Full Access)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=pibit2026

# User Credentials (View Only Access)
# USER_USERNAME=user
# USER_PASSWORD=user123

# JWT Secret Key
# JWT_SECRET=your-secret-jwt-key-change-this-in-production

# Google Drive API Configuration (Optional)
# Path to your Google service account credentials JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# Optional: Specific folder ID to upload files to
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here
